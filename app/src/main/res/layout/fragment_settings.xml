<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="@dimen/fragment_horizontal_margin"
    android:paddingTop="@dimen/fragment_vertical_margin"
    android:paddingRight="@dimen/fragment_horizontal_margin"
    android:paddingBottom="@dimen/fragment_vertical_margin"
    tools:context=".SettingsFragment">

    <!-- Верхняя панель -->
    <include
        layout="@layout/toolbar_with_close"
        android:id="@+id/includeToolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Основной контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/includeToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_large">

            <!-- Заголовок Настройки -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/settings_title"
                android:textColor="@color/darkBlue"
                android:textSize="@dimen/text_xlarge"
                android:layout_marginBottom="@dimen/margin_xlarge" />

            <!-- Тема оформления -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_large">

                <ImageView
                    android:id="@+id/ivThemeIcon"
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/baseline_dark_mode_24"
                    android:contentDescription="@string/settings_theme_icon_desc"
                    app:tint="@color/darkBlue" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_large"
                    android:text="@string/settings_dark_theme"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_normal"
                    android:fontFamily="@font/inter" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/change_theme"
                    app:thumbTint="@color/darkBlue" />

            </LinearLayout>

            <!-- Bluetooth -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_large">

                <ImageView
                    android:id="@+id/ivBluetoothIcon"
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/baseline_bluetooth_24"
                    android:contentDescription="@string/settings_bluetooth_icon_desc"
                    app:tint="@color/darkBlue" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_large"
                    android:text="@string/settings_bluetooth"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_normal"
                    android:fontFamily="@font/inter" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBluetooth"
                    android:contentDescription="@string/settings_bluetooth_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/darkBlue"/>

            </LinearLayout>

            <!-- Назначить устройство по умолчанию -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_xlarge"
                android:background="@drawable/bg_stat_card"
                android:padding="@dimen/margin_default"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/llDefaultDevice">

                <ImageView
                    android:id="@+id/ivDefaultDeviceIcon"
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/baseline_speaker_phone_24"
                    android:contentDescription="@string/settings_default_device_icon_desc"
                    app:tint="@color/darkBlue" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/margin_large"
                    android:text="@string/settings_default_device"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_normal"
                    android:fontFamily="@font/inter" />

            </LinearLayout>

            <!-- Блок для Преподавателя -->
            <LinearLayout
                android:id="@+id/teacherBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:layout_marginBottom="@dimen/margin_default"
                    android:fontFamily="@font/inter_semibold"
                    android:text="@string/settings_teacher_section_title"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_large" />

                <!-- Поле ввода минут -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/margin_large">

                    <ImageView
                        android:id="@+id/ivScanIntervalIcon"
                        android:layout_width="@dimen/icon_small"
                        android:layout_height="@dimen/icon_small"
                        android:src="@drawable/baseline_watch_24"
                        android:contentDescription="@string/settings_scan_interval_icon_desc"
                        app:tint="@color/darkBlue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_large"
                        android:text="@string/settings_scan_interval_label"
                        android:textColor="@color/darkBlue"
                        android:textSize="@dimen/text_normal"
                        android:fontFamily="@font/inter" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <EditText
                            android:id="@+id/etScanInterval"
                            android:layout_width="@dimen/edittext_width_small"
                            android:layout_height="@dimen/edittext_height"
                            android:gravity="center"
                            android:inputType="number"
                            android:autofillHints="scan_interval_minutes"
                            android:hint="@string/settings_scan_interval_hint"
                            android:textColor="@color/darkBlue"
                            android:backgroundTint="@color/transparent"
                            android:textColorHint="@color/darkBlue"
                            android:textSize="@dimen/text_normal"
                            android:background="@drawable/bg_edit_text"
                            android:padding="@dimen/edittext_padding" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_scan_interval_minutes"
                            android:textColor="@color/darkBlue"
                            android:textSize="@dimen/text_small"
                            android:alpha="0.6" />

                    </LinearLayout>

                    <!-- Кнопка Сохранить -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveInterval"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:elevation="0dp"
                        app:elevation="0dp"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_small"
                        android:text="@string/settings_save_button"
                        android:contentDescription="@string/settings_save_button_desc"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:textColor="@color/darkBlue"
                        android:textSize="@dimen/text_medium"
                        app:backgroundTint="@color/transparent"
                        app:strokeWidth="@dimen/stroke_medium"
                        app:strokeColor="@color/darkBlue"
                        app:cornerRadius="@dimen/radius_small" />

                </LinearLayout>

                <!-- Сообщение об ошибке -->
                <TextView
                    android:id="@+id/tvIntervalError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_interval_error"
                    android:textColor="@color/red"
                    android:textSize="@dimen/text_small"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/margin_medium"
                    android:layout_marginTop="@dimen/margin_small" />

            </LinearLayout>

            <!-- Заголовок Профиль -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                android:layout_marginBottom="@dimen/margin_default"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/settings_profile_title"
                android:textColor="@color/darkBlue"
                android:textSize="@dimen/text_large" />

            <!-- ФИО -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/margin_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_full_name_label"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_medium"
                    android:alpha="0.7"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_default"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/margin_default"
                    android:paddingEnd="@dimen/margin_default"
                    tools:text="@string/current_user_name"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_medium"
                    android:fontFamily="@font/inter" />

            </LinearLayout>

            <!-- Блок для Студента/Старосты -->
            <LinearLayout
                android:id="@+id/studentBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_group_label"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_medium"
                    android:alpha="0.7"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:id="@+id/tvGroupNumber"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_default"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/margin_default"
                    android:paddingEnd="@dimen/margin_default"
                    tools:text="@string/current_user_group"
                    android:textColor="@color/darkBlue"
                    android:textSize="@dimen/text_medium"
                    android:fontFamily="@font/inter" />

            </LinearLayout>

            <!-- Кнопка Выйти -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:contentDescription="@string/settings_logout_button_desc"
                android:layout_width="@dimen/button_width_large"
                android:layout_height="@dimen/button_height_default"
                android:layout_marginTop="@dimen/margin_2xlarge"
                android:fontFamily="@font/inter"
                android:text="@string/settings_logout_button"
                android:textAlignment="center"
                android:backgroundTint="@color/transparent"
                android:textColor="@color/darkBlue"
                android:textSize="@dimen/text_medium"
                app:strokeColor="@color/darkBlue"
                app:strokeWidth="@dimen/stroke_large"
                app:cornerRadius="@dimen/radius_small"
                app:icon="@drawable/baseline_logout_24"
                app:iconGravity="textStart"
                app:iconTint="@color/darkBlue" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>