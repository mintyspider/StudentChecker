<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/card_padding"
    android:descendantFocusability="blocksDescendants"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_edit_text"
        android:padding="@dimen/edittext_padding"
        android:gravity="center"
        android:text="Паньков Владислав О."
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tvGroup"
        app:layout_constraintHorizontal_weight="2"/>

    <TextView
        android:id="@+id/tvGroup"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_edit_text"
        android:padding="@dimen/edittext_padding"
        android:gravity="center"
        android:text="22306"
        android:layout_marginStart="@dimen/margin_default"
        android:layout_marginEnd="@dimen/margin_default"
        app:layout_constraintTop_toTopOf="@+id/tvName"
        app:layout_constraintBottom_toBottomOf="@+id/tvName"
        app:layout_constraintStart_toEndOf="@+id/tvName"
        app:layout_constraintEnd_toStartOf="@+id/tvAttendance"
        app:layout_constraintHorizontal_weight="1"/>

    <TextView
        android:id="@+id/tvAttendance"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_edit_text"
        android:padding="@dimen/edittext_padding"
        android:gravity="center"
        android:text="Н"
        android:drawableEnd="@drawable/baseline_mode_24"
        app:layout_constraintTop_toTopOf="@+id/tvName"
        app:layout_constraintBottom_toBottomOf="@+id/tvName"
        app:layout_constraintStart_toEndOf="@+id/tvGroup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

</androidx.constraintlayout.widget.ConstraintLayout>