<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FirstInitFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="@dimen/fragment_horizontal_margin"
        android:paddingTop="@dimen/fragment_vertical_margin"
        android:paddingRight="@dimen/fragment_horizontal_margin"
        android:paddingBottom="@dimen/fragment_vertical_margin">

        <!-- App Name -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_3xlarge"
            android:layout_marginTop="@dimen/margin_3xlarge"
            android:fontFamily="sans-serif-light"
            android:text="@string/appName"
            android:textColor="@color/darkBlue"
            android:textSize="@dimen/appNameSize"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:contentDescription="@string/action_sign_in"
            android:layout_width="@dimen/logo_size"
            android:layout_height="@dimen/logo_size"
            android:src="@drawable/logo"
            app:layout_constraintBottom_toTopOf="@+id/btnEnter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Приветствие -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_top_greeting"
            android:fontFamily="@font/inter"
            android:text="@string/greetingH1"
            android:textAlignment="center"
            android:textColor="@color/darkBlue"
            android:textSize="@dimen/text_large"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivLogo" />

        <!-- Описание -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_top_description"
            android:fontFamily="@font/inter"
            android:lineSpacingExtra="@dimen/description_line_spacing"
            android:text="@string/greetingP"
            android:textAlignment="center"
            android:textColor="@color/darkBlue"
            android:textSize="@dimen/text_medium"
            android:alpha="0.7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvGreeting" />

        <!-- Кнопка входа (исправлена) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnter"
            android:layout_width="@dimen/button_width_large"
            android:layout_height="@dimen/button_height_default"
            android:layout_marginStart="@dimen/margin_2xlarge"
            android:layout_marginEnd="@dimen/margin_2xlarge"
            android:layout_marginBottom="@dimen/button_margin_bottom"
            android:fontFamily="@font/inter"
            android:text="@string/btnGreeting"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/text_medium"
            app:backgroundTint="@color/darkBlue"
            app:cornerRadius="@dimen/radius_large"
            app:icon="@drawable/baseline_login_24"
            app:iconSize="@dimen/icon_small"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>